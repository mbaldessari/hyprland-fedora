# No man pages for hyprpm and start-hyprland; Hyprland.1 covers hyprland
# No test suite available in build
# Intentionally obsoleting old package names without providing them
# uwsm subpackage only contains a desktop file
# devel subpackage contains only headers and pkgconfig
Filters = [
    'no-manual-page-for-binary',
    'no-%check-section',
    'obsolete-not-provided',
    'no-binary',
    'no-documentation',
    'only-non-binary-in-usr-lib',
]
